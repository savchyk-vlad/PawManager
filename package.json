{
  "name": "pawmanager",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:testflight": "eas build --platform ios --profile testflight",
    "submit:testflight": "eas submit --platform ios --profile testflight --latest",
    "release:testflight": "npm run build:testflight && npm run submit:testflight",
    "test": "tsx --test src/**/*.test.ts",
    "check:env": "node scripts/verify-env.js",
    "clean:cache": "node scripts/clean-cache.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "@supabase/supabase-js": "^2.104.1",
    "apple-signin-auth": "^2.0.0",
    "babel-preset-expo": "~54.0.10",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-background-task": "~1.0.10",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
